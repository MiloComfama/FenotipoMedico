# Copia este archivo como ".env" y completa los valores.

# Clave para el chat conversacional con el modelo Opus 4.8.
# Si se deja vacía, el asistente de ingreso usa un flujo guiado de respaldo (sin IA).
# - Si usas la API directa de Anthropic: tu API key (empieza con "sk-ant-...").
# - Si usas Azure AI Foundry: la clave del recurso de Azure (ver ANTHROPIC_FOUNDRY_RESOURCE abajo).
ANTHROPIC_API_KEY=

# Modelo a usar.
# - Si usas la API directa de Anthropic: el model id, ej. claude-opus-4-8.
# - Si usas Azure AI Foundry: el nombre del DEPLOYMENT que configuraste en Azure
#   (no necesariamente coincide con el model id de Anthropic).
ANTHROPIC_MODEL=claude-opus-4-8

# Solo si el modelo se consume vía Azure AI Foundry (no la API directa de Anthropic):
# nombre del recurso de Azure (el que aparece en el endpoint, ej. para
# https://mi-recurso.services.ai.azure.com/ el valor es "mi-recurso").
# Déjalo vacío si usas la API directa de Anthropic.
ANTHROPIC_FOUNDRY_RESOURCE=

# Cuenta de Azure AD con permiso de lectura sobre LH_FabricData, para
# consultar los exámenes médicos (ayudas diagnósticas) en Microsoft Fabric
# desde la consola médica. Autenticación interactiva (se abre una ventana de
# login/MFA la primera vez); no requiere contraseña.
# Si se deja vacía, la consola médica no ofrece la consulta automática de
# exámenes (el médico sigue pudiendo ingresarlos manualmente).
FABRIC_SQL_USER=

# ElevenLabs (texto a voz): habilita el botón "🔊 Escuchar" en el
# cuestionario, para personas con baja visión o dificultades de lectura.
# Si se deja vacía, el botón no aparece (el cuestionario sigue funcionando
# normalmente por texto).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
